DEBUG=false
NODE_ENV=develop

SERVICE_NAME=

# ********************
# Platform Services
# ********************

# Gateway
GATEWAY_API_PORT=3001
GATEWAY_GRPC_PORT=5001

# Assets
ASSETS_API_PORT=3002
ASSETS_GRPC_PORT=5002

# ********************
# Application Services
# ********************

# Auth / Authorization
AUTH_AUTHORIZATION_API_PORT=3050
AUTH_AUTHORIZATION_GRPC_PORT=5050

# Auth / Authentication
AUTH_AUTHENTICATION_API_PORT=3051
AUTH_AUTHENTICATION_GRPC_PORT=5051

# Apps
APPS_API_PORT=3052
APPS_GRPC_PORT=5052

# Users
USERS_API_PORT=3053
USERS_GRPC_PORT=5053

# Grants
GRANTS_API_PORT=3054
GRANTS_GRPC_PORT=5054

# Clients
CLIENTS_API_PORT=3055
CLIENTS_GRPC_PORT=5055

# Configs
CONFIGS_API_PORT=3056
CONFIGS_GRPC_PORT=5056

# Sessions
SESSIONS_API_PORT=3057
SESSIONS_GRPC_PORT=5057

# Profiles
PROFILES_API_PORT=3058
PROFILES_GRPC_PORT=5058

# Artifacts
ARTIFACTS_API_PORT=3059
ARTIFACTS_GRPC_PORT=5059

# ********************
# Logging Services
# ********************

# Sentry
SENTRY_DSN=

# Logging
LOG_DEBUG=*
LOG_LEVEL=notice

# ********************
# Storage Services
# ********************

# Mongo
MONGO_DB=wenex
MONGO_USER=
MONGO_PASS=
MONGO_PORT=27017
MONGO_HOST=localhost

# Redis
REDIS_PORT=6379
REDIS_HOST=localhost
REDIS_PASSWORD=

# Minio
MINIO_HOST=localhost
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ********************
# Broker Services
# ********************

# kafka
KAFKA_HOST=
KAFKA_PORT=
KAFKA_CLIENT_USER=
KAFKA_CLIENT_PASSWORD=

# ********************
# Telemetry Services
# ********************

# Zipkin
ZIPKIN_URL=

# Prometheus
PROMETHEUS_PORT=9464
PROMETHEUS_ENDPOINT=metrics

# OpenTelemetery
OTLP_PORT=4318
OTLP_HOST=otelcol

# Jaeger
JAEGER_SERVICE_PORT=16686
JAEGER_SERVICE_HOST=jeager
