DEBUG=false
NODE_ENV=develop

# ********************
# Platform Services
# ********************

# Gateway
GATEWAY_API_PORT=3000
GATEWAY_GRPC_PORT=5000

# Assets
ASSETS_API_PORT=3001
ASSETS_GRPC_PORT=5001

# ********************
# Application Services
# ********************

# Auth / Authorization
AUTH_AUTHORIZATION_API_PORT=3010
AUTH_AUTHORIZATION_GRPC_PORT=5010

# Auth / Authentication
AUTH_AUTHENTICATION_API_PORT=3011
AUTH_AUTHENTICATION_GRPC_PORT=5011

# Apps
APPS_API_PORT=3012
APPS_GRPC_PORT=5012

# Users
USERS_API_PORT=3013
USERS_GRPC_PORT=5013

# Grants
GRANTS_API_PORT=3014
GRANTS_GRPC_PORT=5014

# Clients
CLIENTS_API_PORT=3015
CLIENTS_GRPC_PORT=5015

# Configs
CONFIGS_API_PORT=3016
CONFIGS_GRPC_PORT=5016

# Sessions
SESSIONS_API_PORT=3017
SESSIONS_GRPC_PORT=5017

# Profiles
PROFILES_API_PORT=3018
PROFILES_GRPC_PORT=5018

# Artifacts
ARTIFACTS_API_PORT=3019
ARTIFACTS_GRPC_PORT=5019

# ********************
# Logging Services
# ********************

# Sentry
SENTRY_DSN=

# ********************
# Storage Services
# ********************

# Mongo
MONGO_DB=develop
MONGO_USER=
MONGO_PASS=
MONGO_PORT=27017
MONGO_HOST=0.0.0.0

# Redis
REDIS_PORT=6379
REDIS_HOST=0.0.0.0
REDIS_PASSWORD=

# Minio
MINIO_HOST=0.0.0.0
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ********************
# Broker Services
# ********************

# kafka
KAFKA_HOST=
KAFKA_PORT=
KAFKA_CLIENT_USER=
KAFKA_CLIENT_PASSWORD=

# ********************
# Telemetry Services
# ********************

# OpenTelemetery
OTLP_PORT=4318
OTLP_HOST=otelcol

# Jaeger
JAEGER_SERVICE_PORT=16686
JAEGER_SERVICE_HOST=jeager
