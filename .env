DEBUG=false
NODE_ENV=develop

SERVICE_NAME=

# ********************
# Logging Services
# ********************

# Sentry
SENTRY_DSN=

# Logging
LOG_DEBUG=*
LOG_LEVEL=notice

# ********************
# Storage Services
# ********************

# Mongo
MONGO_DB=wenex
MONGO_USER=
MONGO_PASS=
MONGO_PORT=27017
MONGO_HOST=localhost

# Redis
REDIS_PORT=6379
REDIS_HOST=localhost
REDIS_PASSWORD=

# Minio
MINIO_HOST=localhost
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ********************
# Broker Services
# ********************

# kafka
KAFKA_HOST=
KAFKA_PORT=

KAFKAJS_NO_PARTITIONER_WARNING=1

# ********************
# Telemetry Services
# ********************

# Zipkin
ZIPKIN_URL=

# Prometheus
PROMETHEUS_PORT=9464
PROMETHEUS_ENDPOINT=metrics

# OpenTelemetery
OTLP_PORT=4318
OTLP_HOST=otelcol

# Jaeger
JAEGER_SERVICE_PORT=16686
JAEGER_SERVICE_HOST=jeager
