{
  "name": "platform",
  "version": "0.0.1",
  "description": "Wenex Platform",
  "author": "Vahid V. <vhid.vz@gmail.com>",
  "license": "Apache-2.0",
  "scripts": {
    "build": "nest build",
    "setup": "sh ./script/setup.sh",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:repl": "nest start --entryFile repl",
    "start:debug": "nest start --debug --watch",
    "start:debug2": "nest start --debug 9228 --watch",
    "start:prod": "node dist/apps/platform/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/platform/test/jest-e2e.json",
    "command": "node -r tsconfig-paths/register -r ts-node/register libs/command/src/main.ts",
    "command:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register libs/command/src/main.ts",
    "db:clean": "npm run command -- db clean",
    "db:seed": "npm run command -- db seed",
    "db:debug": "npm run command:debug -- db",
    "mongo:drop": "npm run command -- mongo drop",
    "mongo:seed": "npm run command -- mongo seed",
    "mongo:debug": "npm run command:debug -- mongo",
    "storage:init": "npm run command -- storage init",
    "storage:debug": "npm run command:debug -- storage",
    "doc": "npx compodoc -p tsconfig.json -n \"Wenex Documentation\" -d ./docs -s"
  },
  "dependencies": {
    "@nestjs/common": "^10.2.7",
    "@nestjs/core": "^10.2.7",
    "@nestjs/graphql": "^12.0.9",
    "@nestjs/microservices": "^10.2.7",
    "@nestjs/platform-express": "^10.2.7",
    "@nestjs/swagger": "^7.1.13",
    "@nestjs/terminus": "^10.1.1",
    "@opentelemetry/auto-instrumentations-node": "^0.39.3",
    "@opentelemetry/exporter-trace-otlp-http": "^0.44.0",
    "@opentelemetry/exporter-zipkin": "^1.17.1",
    "@opentelemetry/instrumentation": "^0.44.0",
    "@opentelemetry/instrumentation-express": "^0.33.2",
    "@opentelemetry/instrumentation-grpc": "^0.44.0",
    "@opentelemetry/instrumentation-http": "^0.44.0",
    "@opentelemetry/instrumentation-nestjs-core": "^0.33.2",
    "@opentelemetry/resources": "^1.17.1",
    "@opentelemetry/sdk-node": "^0.44.0",
    "@opentelemetry/sdk-trace-node": "^1.17.1",
    "@opentelemetry/semantic-conventions": "^1.17.1",
    "ioredis": "^5.3.2",
    "opentelemetry-instrumentation-kafkajs": "^0.39.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.1.18",
    "@nestjs/schematics": "^10.0.2",
    "@nestjs/testing": "^10.2.7",
    "@types/express": "^4.17.19",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.8.6",
    "@types/supertest": "^2.0.14",
    "@typescript-eslint/eslint-plugin": "^6.7.5",
    "@typescript-eslint/parser": "^6.7.5",
    "eslint": "^8.51.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": "^18.15.0",
    "npm": "^9.5.0"
  }
}
