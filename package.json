    "kafkajs": "^2.2.4",
    "log": "^6.3.1",
    "log-node": "^8.0.3",
    "mongoose": "^7.1.0",
    "multer-s3": "^3.0.1",
    "naming-conventions-modeler": "^1.4.0",
    "prom-client": "^14.2.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^9.4.2",
    "@nestjs/schematics": "^9.1.0",
    "@nestjs/testing": "^9.4.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/crypto-js": "^4.1.1",
    "@types/express": "^4.17.17",
    "@types/jest": "29.5.1",
