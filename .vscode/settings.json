{
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": true
    },
    "git.mergeEditor": true,
    "docwriter.style": "Auto-detect",
    "editor.tabCompletion": "on",
    "diffEditor.codeLens": true,
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/node_modules": true
    },
    "cSpell.words": [
        "metinseylan",
        "nestjs",
        "opentelemetry",
        "OTLP",
        "proto",
        "protos",
        "Vahid",
        "webpush",
        "Zipkin"
    ]
}